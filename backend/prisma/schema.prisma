generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema", "partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["audit", "monitoring", "nexa"]
}

/// This table is a partition table and requires additional setup for migrations. Visit https://pris.ly/d/partition-tables for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_logs {
  id            BigInt       @default(autoincrement())
  occurred_at   DateTime     @default(now()) @db.Timestamptz(6)
  user_id       String?      @db.Uuid
  user_email    String?      @db.VarChar(255)
  user_role     String?
  ip_address    String?      @db.Inet
  user_agent    String?
  action        audit_action
  schema_name   String?      @db.VarChar(100)
  table_name    String?      @db.VarChar(100)
  record_id     String?
  old_values    Json?
  new_values    Json?
  context       Json?
  success       Boolean      @default(true)
  error_message String?

  @@id([id, occurred_at])
  @@index([action], map: "idx_audit_action")
  @@index([occurred_at(sort: Desc)], map: "idx_audit_occurred_at")
  @@index([table_name, schema_name], map: "idx_audit_table")
  @@index([table_name, action, occurred_at(sort: Desc)], map: "idx_audit_table_action")
  @@index([user_id, occurred_at(sort: Desc)], map: "idx_audit_user_date", where: raw("(user_id IS NOT NULL)"))
  @@index([user_id], map: "idx_audit_user_id", where: raw("(user_id IS NOT NULL)"))
  @@schema("audit")
}

model backup_log {
  id            BigInt    @id @default(autoincrement())
  started_at    DateTime  @db.Timestamptz(6)
  completed_at  DateTime? @db.Timestamptz(6)
  backup_type   String
  destination   String
  size_bytes    BigInt?
  success       Boolean   @default(false)
  error_message String?
  duration_secs Decimal?  @default(dbgenerated("EXTRACT(epoch FROM (completed_at - started_at))")) @db.Decimal

  @@schema("monitoring")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sla_alerts {
  id           BigInt   @id @default(autoincrement())
  ticket_id    String   @db.Uuid
  alert_type   String
  triggered_at DateTime @default(now()) @db.Timestamptz(6)
  notified     Boolean  @default(false)
  tickets      tickets  @relation(fields: [ticket_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([ticket_id, alert_type], map: "sla_alerts_unique")
  @@schema("monitoring")
}

model slow_query_log {
  id            BigInt   @id @default(autoincrement())
  logged_at     DateTime @default(now()) @db.Timestamptz(6)
  query_text    String
  duration_ms   Decimal  @db.Decimal
  user_name     String?
  database_name String?
  rows_examined BigInt?

  @@schema("monitoring")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model contract_signatures {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  contract_id          String    @db.Uuid
  user_id              String    @db.Uuid
  signature_image      String?
  ip_address           String    @db.Inet
  content_hash_at_sign String    @db.VarChar(64)
  signed_at            DateTime  @default(now()) @db.Timestamptz(6)
  contracts            contracts @relation(fields: [contract_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([contract_id, user_id], map: "contract_signatures_unique")
  @@schema("nexa")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model contract_versions {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  contract_id    String    @db.Uuid
  version_number Int       @db.SmallInt
  content        String
  content_hash   String    @db.VarChar(64)
  created_by     String    @db.Uuid
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  contracts      contracts @relation(fields: [contract_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          users     @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([contract_id, version_number], map: "contract_versions_unique")
  @@index([contract_id], map: "idx_contract_versions_contract")
  @@schema("nexa")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model contracts {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  project_id          String                @db.Uuid
  title               String                @db.VarChar(255)
  content             String
  content_hash        String                @db.VarChar(64)
  status              contract_status       @default(PENDING)
  created_by          String                @db.Uuid
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  contract_signatures contract_signatures[]
  contract_versions   contract_versions[]
  users               users                 @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects            projects              @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([project_id], map: "idx_contracts_project")
  @@index([status], map: "idx_contracts_status")
  @@schema("nexa")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model demand_assignees {
  id                                        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  demand_id                                 String   @db.Uuid
  user_id                                   String   @db.Uuid
  assigned_at                               DateTime @default(now()) @db.Timestamptz(6)
  assigned_by                               String   @db.Uuid
  users_demand_assignees_assigned_byTousers users    @relation("demand_assignees_assigned_byTousers", fields: [assigned_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  demands                                   demands  @relation(fields: [demand_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_demand_assignees_user_idTousers     users    @relation("demand_assignees_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([demand_id, user_id], map: "demand_assignees_unique")
  @@index([demand_id], map: "idx_demand_assignees_demand")
  @@index([user_id], map: "idx_demand_assignees_user")
  @@schema("nexa")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model demand_files {
  id              String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  demand_id       String?          @db.Uuid
  subfolder       demand_subfolder
  file_name       String           @db.VarChar(500)
  file_key        String           @unique
  file_size_bytes BigInt
  mime_type       String           @db.VarChar(255)
  uploaded_by     String           @db.Uuid
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  project_id      String?          @db.Uuid
  demands         demands?         @relation(fields: [demand_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  projects        projects?        @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           users            @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([demand_id], map: "idx_demand_files_demand")
  @@index([project_id], map: "idx_demand_files_project", where: raw("(project_id IS NOT NULL)"))
  @@index([subfolder], map: "idx_demand_files_subfolder")
  @@schema("nexa")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model demands {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  project_id       String             @db.Uuid
  title            String             @db.VarChar(255)
  description      String?
  deadline         DateTime           @db.Timestamptz(6)
  status           demand_status      @default(PENDING)
  created_by       String             @db.Uuid
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  demand_assignees demand_assignees[]
  demand_files     demand_files[]
  users            users              @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects         projects           @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([deadline], map: "idx_demands_deadline")
  @@index([description(ops: raw("gin_trgm_ops"))], map: "idx_demands_desc_trgm", type: Gin)
  @@index([project_id], map: "idx_demands_project")
  @@index([status], map: "idx_demands_status")
  @@index([title(ops: raw("gin_trgm_ops"))], map: "idx_demands_title_trgm", type: Gin)
  @@schema("nexa")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model financial_entries {
