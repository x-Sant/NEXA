  paid_by                                   String?          @db.Uuid
  users_financial_entries_created_byTousers users            @relation("financial_entries_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_financial_entries_paid_byTousers    users?           @relation("financial_entries_paid_byTousers", fields: [paid_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects                                  projects?        @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([due_date], map: "idx_financial_due_date")
  @@index([project_id], map: "idx_financial_project", where: raw("(project_id IS NOT NULL)"))
  @@index([status], map: "idx_financial_status")
  @@index([type], map: "idx_financial_type")
  @@schema("nexa")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model notifications {
  id            String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
