/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model projects {
  id                              String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                            String              @db.VarChar(255)
  description                     String?
  deadline                        DateTime            @db.Timestamptz(6)
  status                          project_status      @default(ACTIVE)
  owner_id                        String              @db.Uuid
  client_id                       String?             @db.Uuid
  created_at                      DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime            @default(now()) @db.Timestamptz(6)
  contracts                       contracts[]
  demand_files                    demand_files[]
  demands                         demands[]
  financial_entries               financial_entries[]
  project_members                 project_members[]
  users_projects_client_idTousers users?              @relation("projects_client_idTousers", fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_projects_owner_idTousers  users               @relation("projects_owner_idTousers", fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tickets                         tickets[]

  @@index([client_id], map: "idx_projects_client", where: raw("(client_id IS NOT NULL)"))
  @@index([deadline], map: "idx_projects_deadline")
  @@index([owner_id], map: "idx_projects_owner")
  @@index([status], map: "idx_projects_status")
  @@schema("nexa")
}

model ticket_responses {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  ticket_id  String   @db.Uuid
  author_id  String   @db.Uuid
  message    String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [author_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tickets    tickets  @relation(fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("nexa")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tickets {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  project_id       String?            @db.Uuid
  creator_id       String             @db.Uuid
  subject          String             @db.VarChar(500)
  description      String
  status           ticket_status      @default(OPEN)
  sla_deadline     DateTime           @db.Timestamptz(6)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  sla_alerts       sla_alerts[]
  ticket_responses ticket_responses[]
  users            users              @relation(fields: [creator_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects         projects?          @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([creator_id], map: "idx_tickets_creator")
  @@index([project_id], map: "idx_tickets_project", where: raw("(project_id IS NOT NULL)"))
  @@index([sla_deadline], map: "idx_tickets_sla", where: raw("(status = ANY (ARRAY['OPEN'::nexa.ticket_status, 'IN_PROGRESS'::nexa.ticket_status]))"))
  @@index([status], map: "idx_tickets_status")
  @@schema("nexa")
}

model user_sessions {
  id                 String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id            String   @db.Uuid
  refresh_token_hash String   @unique @db.VarChar(64)
  ip_address         String   @db.Inet
  user_agent         String?
  expires_at         DateTime @db.Timestamptz(6)
  is_revoked         Boolean  @default(false)
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  users              users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_sessions_expires", where: raw("(is_revoked = false)"))
  @@index([user_id, is_revoked, expires_at], map: "idx_sessions_user_active", where: raw("(is_revoked = false)"))
  @@index([user_id], map: "idx_sessions_user_id")
  @@schema("nexa")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                                                     String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email                                                  String                @unique(map: "users_email_unique") @db.VarChar(255)
  password_hash                                          String
  name                                                   String                @db.VarChar(255)
  role                                                   user_role
  avatar_url                                             String?
  cpf_cnpj_encrypted                                     Bytes?
  cpf_cnpj_hash                                          String?               @unique @db.VarChar(64)
  is_active                                              Boolean               @default(true)
  password_needs_change                                  Boolean               @default(false)
  last_login_at                                          DateTime?             @db.Timestamptz(6)
  failed_login_count                                     Int                   @default(0) @db.SmallInt
  locked_until                                           DateTime?             @db.Timestamptz(6)
  reset_token_hash                                       String?               @db.VarChar(64)
  reset_token_expires                                    DateTime?             @db.Timestamptz(6)
  created_at                                             DateTime              @default(now()) @db.Timestamptz(6)
  updated_at                                             DateTime              @default(now()) @db.Timestamptz(6)
  contract_signatures                                    contract_signatures[]
  contract_versions                                      contract_versions[]
  contracts                                              contracts[]
  demand_assignees_demand_assignees_assigned_byTousers   demand_assignees[]    @relation("demand_assignees_assigned_byTousers")
  demand_assignees_demand_assignees_user_idTousers       demand_assignees[]    @relation("demand_assignees_user_idTousers")
  demand_files                                           demand_files[]
  demands                                                demands[]
  financial_entries_financial_entries_created_byTousers  financial_entries[]   @relation("financial_entries_created_byTousers")
  financial_entries_financial_entries_paid_byTousers     financial_entries[]   @relation("financial_entries_paid_byTousers")
  notifications                                          notifications[]
  professor_comments_professor_comments_author_idTousers professor_comments[]  @relation("professor_comments_author_idTousers")
  professor_comments_professor_comments_target_idTousers professor_comments[]  @relation("professor_comments_target_idTousers")
  profitability_goals                                    profitability_goals[]
  project_members                                        project_members[]
  projects_projects_client_idTousers                     projects[]            @relation("projects_client_idTousers")
  projects_projects_owner_idTousers                      projects[]            @relation("projects_owner_idTousers")
  ticket_responses                                       ticket_responses[]
  tickets                                                tickets[]
  user_sessions                                          user_sessions[]

  @@index([is_active], map: "idx_users_active", where: raw("(is_active = true)"))
  @@index([cpf_cnpj_hash], map: "idx_users_cpf_cnpj_hash", where: raw("(cpf_cnpj_hash IS NOT NULL)"))
  @@index([role], map: "idx_users_role")
  @@schema("nexa")
}

enum audit_action {
  INSERT
  UPDATE
  DELETE
  SELECT
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PERMISSION_DENIED

  @@schema("audit")
}

enum contract_status {
  PENDING
  APPROVED
  REJECTED

  @@schema("nexa")
}

enum demand_status {
  PENDING
  IN_PROGRESS
  REVIEW
  COMPLETED

  @@schema("nexa")
}

enum demand_subfolder {
  front
  back
  bd
  imgs
  git
  commits
  zip
  referencias
  contratos

  @@schema("nexa")
}

enum financial_status {
  PENDING
  PAID
  OVERDUE
  CANCELLED

  @@schema("nexa")
}

enum financial_type {
  PAYABLE
  RECEIVABLE

  @@schema("nexa")
}

enum notification_type {
  CONTRACT_PENDING_SIGNATURE
  TICKET_ASSIGNED
  TICKET_RESPONSE
  SLA_WARNING
  SLA_BREACH
  DEMAND_ASSIGNED
  PROJECT_STATUS_CHANGED
  PROFESSOR_COMMENT

  @@schema("nexa")
}

enum project_status {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED

  @@schema("nexa")
}

enum ticket_status {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED

  @@schema("nexa")
}

enum user_role {
  NIVEL_1
  NIVEL_2
  NIVEL_3
  PROFESSOR
  CLIENTE

  @@schema("nexa")
}
