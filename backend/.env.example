# Configurações do Banco de Dados
DATABASE_URL="postgresql://postgres:password@localhost:5432/nexa"

# JWT Secret para autenticação
JWT_SECRET="sua-chave-secreta-forte-aqui-minimo-64-caracteres"
JWT_EXPIRES_IN="15m"

# CPF Crypto Key (usada pelo pgcrypto no PostgreSQL)
CPF_CRYPTO_KEY="sua-chave-de-criptografia-para-cpf-cnpj"

# Supabase (Storage, Auth)
SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_ANON_KEY="sua-chave-anon"
SUPABASE_SERVICE_ROLE_KEY="sua-chave-service-role"

# Outras Configurações
PORT=3001
ALLOWED_ORIGINS="http://localhost:3000"
NODE_ENV="development"
